    {% include "header.liquid" %}

    <main class="container">
        <h1>{{ title }}</h1>
        <div class="profile-with-links">
            <img src="/assets/img/me.jpg" alt="Portrait of Milan Vlaški, the creator of this site">
            <nav>
                <a href="https://linkedin.com/in/milan-vlaski/" target="_blank">
                    <svg><use href="#icon-linkedin"></use></svg>
                </a>
                <a href="https://github.com/milanvlaski" target="_blank">
                    <svg><use href="#icon-github"></use></svg>
                </a>
                <a href="{{ "/contact" | locale_url }}">
                    <svg><use href="#icon-mail"></use></svg>
                </a>
            </nav>
        </div>
        {{ content }}
        <h2>{{ t[lang].contact.heading }}</h2>
        {% include "contact_form.liquid" %}
    </main>


    {% include "footer.liquid" %}

</body>

</html>
